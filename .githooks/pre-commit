#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 1
cd "$repo_root"

staged_python_files=()
while IFS= read -r -d '' file; do
	staged_python_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.py')

if [[ ${#staged_python_files[@]} -eq 0 ]]; then
	exit 0
fi

scripts/check_style.sh "${staged_python_files[@]}"